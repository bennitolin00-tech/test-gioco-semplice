<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <title>go, stop and jump demo</title>
        <style>
            div{
                position: absolute;
                background-color: #d00000;
                left: 20px;
                top: 100px;
                width: 60px;
                height: 60px;
                margin: 5px;
                border: 1px solid black;
                border-radius: 30px; 
            }

            #go, #stop, #back, #jump, #down, #up{
                margin: 5px;
                float: right;
                margin-top:400px;
                background-color: #b0b6a6;;
                border-radius: 15px;
                padding: 10px;
            }

            #btn, #effectTypes, #btn-color{
                background-color: #b0b6a6;;
                border-radius: 15px;
                padding: 10px;
            }

        </style>
        <link rel="stylesheet" href="../css/style.css"/>
        <link rel ="stylesheet" href="../css/jquery-ui.css"/>
        <script src="../js/jquery-4.0.0.js"></script>
        <script src= "../js/jquery-ui.js"></script>
        
        </head>
    <body>
        <button id="go">Go</button>
        <button id="stop">Stop!</button>
        <button id="back">Back</button>
        <button id="jump">Jump</button>
        <button id="down">Down</button>
        <button id="up">Up</button>
        <div id= "effect" class="block"> </div>

        <!-- <div id="dialog" title="Basic dialog">
        <p>Hello, I'm a ball!</p>
        </div> -->

    <script>
       /* $( function() {
            $( "#dialog" ).dialog();
        } );                             it doesn't work (whyyyyy T.T)*/ 

         $( function() {
                $( ".block" ).draggable();
            } );

        // Start animation
        $("#go").on("click", function(){
            $(".block").animate({left: "+=100px"}, 500);
        });

        // Stop animation when button is clicked
        $("#stop").on("click", function(){
            $(".block").stop();
        });

        // Start animation in the opposite direction
        $("#back").on("click", function(){
            $(".block").animate({left: "-=100px"}, 500);
        });

        // Jump animation
        $("#jump").on("click",function(){
            $(".block").animate({top: "-=200px"}, 500);
            $(".block").animate({top: "+=200px"}, 500);
        });

        // Down animation
        $("#down").on("click",function(){
            $(".block").animate({top: "+=100px"}, 500);
        });

        // Up animation
        $("#up").on("click",function(){
            $(".block").animate({top: "-=100px"}, 500);
        });

        // Fade out block when clicked 
        /*$("div.block").on("dblclick",function(){
            $(this).fadeOut("slow");
            $(this).fadeIn("slow");
        }); */

        //Slide the block when clicked
        $("div.block").on("click",function(){
            $(this).slideUp();
            $(this).slideDown();
        })

    $( function() {
        // run the currently selected effect
        function runEffect() {
        // get effect type from
        var selectedEffect = $( "#effectTypes" ).val();
    
        // Most effect types need no options passed by default
        var options = {};
        // some effects have required parameters
        if ( selectedEffect === "scale" ) {
            options = { percent: 50 };
        } else if ( selectedEffect === "size" ) {
            options = { to: { width: 200, height: 60 } };
        }
    
        // Run the effect
        $( "#effect" ).toggle( selectedEffect, options, 500 );
        };
    
        // Set effect from select menu value
        $( "#btn" ).on( "click", function() {
        runEffect();
        });
    } );

    //Change color
 var url = "https://code.jquery.com/color/jquery.color-3.0.0.min.js";
$.getScript( url, function() {
  $( "#btn-color" ).on( "click", function() {
    $( ".block" )
      .animate({
        backgroundColor: "rgb(255, 180, 180)"
      }, 1000 )
      .delay( 500 )
      .animate({
        backgroundColor: "olive"
      }, 1000 )
      .delay( 500 )
      .animate({
        backgroundColor: "#00f"
      }, 1000 )
      .delay( 500 )
      .animate({
        backgroundColor: "#d00000"
      }, 1000 );
  });
});
  
    </script>

    <select name="effects" id="effectTypes">
    <option value="blind">Blind</option>
    <option value="bounce">Bounce</option>
    <option value="clip">Clip</option>
    <option value="drop">Drop</option>
    <option value="explode">Explode</option>
    <option value="fade">Fade</option>
    <option value="fold">Fold</option>
    <option value="highlight">Highlight</option>
    <option value="puff">Puff</option>
    <option value="pulsate">Pulsate</option>
    <option value="scale">Scale</option>
    <option value="shake">Shake</option>
    <option value="size">Size</option>
    <option value="slide">Slide</option>
    </select>
    
    <button id="btn">Run Effect</button>
    <button id="btn-color">&raquo; Change Color</button>

    </body>
</html>